<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="res_config_settings_view_form_e164" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.e164.normalizer</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.view_res_config_settings"/>
    <field name="arch" type="xml">
      <xpath expr="//div[@id='settings']" position="inside">
        <div class="app_settings_block" data-string="Phone E.164 Normalizer" string="Phone E.164 Normalizer" groups="base.group_system">
          <h2>E.164 Telefonnummern-Normalisierung</h2>
          <div class="row mt16 o_settings_container">
            <div class="col-12 col-lg-6 o_setting_box">
              <div class="o_setting_left_pane"><span class="fa fa-phone"/></div>
              <div class="o_setting_right_pane">
                <label for="e164_active"/>
                <div class="text-muted">Wenn aktiviert, speichert Odoo Telefonnummern (phone/mobile) automatisch im E.164-Format ohne Leerzeichen.</div>
                <div class="content-group">
                  <field name="e164_active"/>
                </div>
              </div>
            </div>
            <div class="col-12 col-lg-6 o_setting_box">
              <div class="o_setting_left_pane"><span class="fa fa-globe"/></div>
              <div class="o_setting_right_pane">
                <label for="e164_default_country_code"/>
                <div class="text-muted">Standard-Ländervorwahl (z. B. +43) für nationale Nummern.</div>
                <div class="content-group">
                  <field name="e164_default_country_code" placeholder="+43"/>
                </div>
              </div>
            </div>
          </div>
        </div>
      </xpath>
    </field>
  </record>
</odoo>
